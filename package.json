{
  "name": "transfer",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:landing": "vite build --config vite.landing.config.ts",
    "deploy": "bun run build:client && bun run build:landing && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "bun run typecheck:worker && bun run typecheck:client",
    "typecheck:worker": "tsc --noEmit -p tsconfig.json",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.3",
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/kumo": "2.6.0",
    "@phosphor-icons/react": "2.1.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "mermaid": "^11.16.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "8.1.3",
    "wrangler": "^4.106.0"
  }
}
